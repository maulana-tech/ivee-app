# ============================================
# WorldMonitor - Crypto Trading (Hackathon)
# ============================================
# Copy this file to .env.local and fill in required values.
#   cp .env.example .env.local

# ============================================
# AVE Cloud API (REQUIRED for Crypto Features)
# ============================================
# Register FREE at: https://cloud.ave.ai/
# Supports 130+ chains: Base, Ethereum, BSC, Solana, etc.
VITE_AVE_API_KEY=
VITE_AVE_API_PLAN=free
VITE_AVE_ENABLED=false

# ============================================
# Site Configuration
# ============================================
# For crypto variant, set to "crypto"
VITE_VARIANT=full

# ============================================
# MARKET DATA (Optional - for stock/market panels)
# ============================================
# Finnhub (free tier available): https://finnhub.io/
FINNHUB_API_KEY=

# ============================================
# AI SUMMARIZATION (Optional - for AI Insights panel)
# ============================================
# Groq API (free tier): https://console.groq.com/
GROQ_API_KEY=

# OpenRouter API (free tier): https://openrouter.ai/
OPENROUTER_API_KEY=
