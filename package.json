{
  "name": "predba",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Canon Polymarket trading client templates and tests",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --ignore-pattern node_modules --ignore-pattern nba-momentum .",
    "test": "vitest run",
    "check": "tsc --noEmit && oxlint . && vitest run",
    "server": "tsx server/index.ts",
    "build": "vite build",
    "dev": "vite",
    "dev:all": "concurrently \"npm run server\" \"npm run dev\""
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "ethers": "~5.7.2",
    "pmxtjs": "2.22.1",
    "pmxt-core": "2.22.1",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "concurrently": "^8.2.2",
    "oxlint": "1.60.0",
    "tsx": "4.21.0",
    "typescript": "5.8.2",
    "vitest": "4.1.4"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
